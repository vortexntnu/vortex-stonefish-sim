<?xml version="1.0"?>
<scenario>
    <robot name="Moby" fixed="false" self_collisions="false">

        <base_link name="Base" type="model" physics="submerged">
            <physical>
                <mesh filename="moby/moby_collision.obj" scale="1.0"/>
                <origin rpy="-1.57 0.0 1.57" xyz="0.0 0.0 0.0"/>
            </physical>

            <visual>
                <mesh filename="moby/moby_visual.obj" scale="1.0"/>
                <origin rpy="-1.57 0.0 1.57" xyz="0.0 0.0 0.0"/>
            </visual>

            <material name="Neutral"/>
            <look name="Grey"/>
            <!-- TODO: update these constants for moby -->
            <mass value="53.7.0"/>
            <inertia xyz="4.1 4.1 6.8"/>
            <hydrodynamics viscous_drag="0.15 0.4 0.4" quadratic_drag="0.4 0.4 0.4"/>
            <cg xyz="-0.0 0.0 0.2" rpy="0.0 0.0 0.0"/>
        </base_link>

        <!-- TODO: add correct thruster orientation and placement -->
        <actuator name="Thruster1" type="thruster">
            <link name="Base"/>
            <origin xyz="0.5 0.2 -0.115" rpy="0 0 -0.7853981634"/>
            <specs max_setpoint="50.0" inverted_setpoint="false" normalized_setpoint="false"/>
            <propeller diameter="0.18" right="true">
                <mesh filename="orca/bluerov2_propccw.obj" scale="1.0"/>
                <material name="robot_material"/>
                <look name="Grey"/>
            </propeller>
            <rotor_dynamics type="zero_order"/>
            <thrust_model type="linear_interpolation">
                <input value="-40.0 -20.0 0.0 20.0 40.0"/>
                <output value="-40.0 -20.0 0.0 20.0 40.0"/>
            </thrust_model>
        </actuator>

