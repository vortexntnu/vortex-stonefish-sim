        <!-- TODO: Add the sensors at the correct place in the drone -->
        <sensor name="camera_front" type="camera" rate="13.0">
			<link name="Base"/>
			<origin rpy="1.571 0.0 1.571" xyz="0.4 0.0 -0.175"/>
			<specs resolution_x="1440" resolution_y="1080" horizontal_fov="90.0"/>
			<ros_publisher topic="/cam"/>
		</sensor>

        <sensor name="camera_down" type="camera" rate="13.0">
			<link name="Base"/>
			<origin rpy="0.0 0.0 1.571" xyz="0.305 -0.085 0.028"/>
			<specs resolution_x="1440" resolution_y="1080" horizontal_fov="90.0"/>
			<ros_publisher topic="/cam_down"/>
		</sensor>

        <sensor name="IMU" rate="20.0" type="imu">
            <range angular_velocity="10.0 10.0 5.0" linear_acceleration="10.0"/>
            <noise angle="0.1 0.1 0.5" angular_velocity="0.05" yaw_drift="0.001" linear_acceleration="0.1"/>
            <history samples="1"/>
            <origin xyz="0.1 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <link name="Base"/>
            <ros_publisher topic="/imu/data_raw"/>
        </sensor>

        <sensor name="odom" type="odometry" rate="5.0">
            <link name="Base"/>
            <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
            <ros_publisher topic="/orca/odom"/>
        </sensor>

        <sensor name="DVL" rate="5.0" type="dvl">
            <specs beam_angle="30.0" beam_positive_z="true"/>
            <range velocity="10.0 10.0 5.0" altitude_min="0.5" altitude_max="50.0"/>
            <water_layer minimum_layer_size="10.0" boundary_near="10.0" boundary_far="30.0"/>
            <noise velocity_percent= "0.3" velocity="0.1" altitude="0.03" water_velocity_percent="0.1" water_velocity="0.1"/>
            <history samples="1"/>
            <origin rpy="0.0 0.0 1.571" xyz="-0.118 -0.005 0.1"/>
            <link name="Base"/>
            <ros_publisher topic="/dvl/sim"/>
        </sensor>

        <!--  <light name="Spot"> -->
        <!--     <specs radius="0.03" cone_angle="35.0" illuminance="2000.0"/> -->
        <!--     <color temperature="5600.0"/> -->
        <!--     <origin xyz="0.25 0.0 -0.075" rpy="-1.57 0.0 -1.57"/> -->
        <!--     <link name="Base"/> -->
        <!-- </light> -->

        <!-- Drone starting pose from launch file -->
        <world_transform xyz="$(param drone_position)" rpy="$(param drone_orientation)"/>

        <ros_subscriber thrusters="/stonefish/thrusters" servos="/stonefish/servos"/>
        <ros_publisher thrusters="/thruster_state" servos="/servo_state"/>
    </robot>
</scenario>
